---
import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang?: Locale;
}

const { lang = "nl" } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-copy">&copy; {currentYear} Pantalytics B.V. {t("footer.copyright")}</p>
    <div class="footer-links">
      <a href="https://www.pantalytics.com" target="_blank" rel="noopener">{t("footer.website")}</a>
      <a href="https://github.com/pantalytics/pantalytics-brand" target="_blank" rel="noopener">{t("footer.github")}</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border-primary);
    padding-block: var(--space-md);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: var(--space-sm);
  }

  .footer-links a {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-text-primary);
  }
</style>
