---
import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang?: Locale;
  activeSection?: string;
}

const { lang = "nl", activeSection } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === "nl" ? "" : "/en";

const sections = [
  { key: "overview", label: t("nav.overview"), href: prefix ? prefix + "/" : "/" },
  { key: "logo", label: t("nav.logo"), href: prefix + "/logo" },
  { key: "colors", label: t("nav.colors"), href: lang === "nl" ? "/kleuren" : "/en/colors" },
  { key: "typography", label: t("nav.typography"), href: lang === "nl" ? "/typografie" : "/en/typography" },
  { key: "voice", label: t("nav.voice"), href: prefix + "/tone-of-voice" },
  { key: "downloads", label: t("nav.downloads"), href: prefix + "/downloads" },
];
---

<aside class="sidebar">
  <nav class="sidebar-nav" aria-label="Brand guide sections">
    <ul>
      {sections.map((section) => (
        <li>
          <a
            href={section.href}
            class:list={["sidebar-link", { active: activeSection === section.key }]}
          >
            {section.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
    border-right: 1px solid var(--color-border-primary);
    padding: var(--space-md) var(--space-sm);
    overflow-y: auto;
  }

  .sidebar-nav ul {
    list-style: none;
  }

  .sidebar-link {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.88rem;
    border-radius: var(--radius-sm);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .sidebar-link:hover {
    color: var(--color-text-primary);
    background-color: var(--color-border-primary);
  }

  .sidebar-link.active {
    color: var(--color-accent);
    background-color: rgba(155, 153, 255, 0.1);
  }

  @media (max-width: 767px) {
    .sidebar {
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--color-border-primary);
      padding: var(--space-sm);
    }

    .sidebar-nav ul {
      display: flex;
      gap: 0.25rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .sidebar-link {
      white-space: nowrap;
      font-size: 0.81rem;
      padding: 0.4rem 0.6rem;
    }
  }
</style>
