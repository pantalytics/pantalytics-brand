---
import BrandLayout from "@/layouts/BrandLayout.astro";
import { useTranslations } from "@/i18n/utils";

const t = useTranslations("nl");
---

<BrandLayout title={t("logo.title")} lang="nl" description={t("logo.intro")} activeSection="logo">
  <h1>{t("logo.h1")}</h1>
  <p class="brand-intro">{t("logo.intro")}</p>

  <h2>{t("logo.variants.title")}</h2>
  <p>{t("logo.variants.desc")}</p>

  <h3>{t("logo.primary.title")}</h3>
  <p>{t("logo.primary.desc")}</p>
  <div class="logo-grid">
    <div class="logo-card" style="background-color: #ffffff;">
      <img src="/images/logo/logo-primary.png" alt="Pantalytics primair logo (blauw + goud) op witte achtergrond" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Primair — wit</span>
    </div>
    <div class="logo-card" style="background-color: var(--color-bg-primary);">
      <img src="/images/logo/logo-primary.png" alt="Pantalytics primair logo op donkere achtergrond" />
      <span class="logo-card-label" style="color: var(--color-text-secondary);">Primair — donker</span>
    </div>
  </div>

  <h3>{t("logo.monochrome.title")}</h3>
  <p>{t("logo.monochrome.desc")}</p>
  <div class="logo-grid">
    <div class="logo-card" style="background-color: #ffffff;">
      <img src="/images/logo/logo-blue.png" alt="Pantalytics monochroom blauw logo" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Monochroom blauw</span>
    </div>
    <div class="logo-card" style="background-color: #ffffff;">
      <img src="/images/logo/logo-gold.png" alt="Pantalytics monochroom goud logo" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Monochroom goud</span>
    </div>
  </div>

  <h3>{t("logo.icon.title")}</h3>
  <p>{t("logo.icon.desc")}</p>
  <div class="logo-grid">
    <div class="logo-card logo-card-icon" style="background-color: #ffffff;">
      <img src="/images/logo/icon-blue.png" alt="Pantalytics icon mark blauw" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Icon — blauw</span>
    </div>
    <div class="logo-card logo-card-icon" style="background-color: #ffffff;">
      <img src="/images/logo/icon-gold.png" alt="Pantalytics icon mark goud" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Icon — goud</span>
    </div>
    <div class="logo-card logo-card-icon" style="background-color: var(--color-bg-primary);">
      <img src="/images/logo/icon-blue.png" alt="Pantalytics icon mark blauw op donker" />
      <span class="logo-card-label" style="color: var(--color-text-secondary);">Icon — blauw/donker</span>
    </div>
  </div>

  <h2>{t("logo.clearspace.title")}</h2>
  <p>{t("logo.clearspace")}</p>

  <h2>{t("logo.minsize.title")}</h2>
  <p>{t("logo.minsize")}</p>

  <h2>{t("logo.dos.title")} & {t("logo.donts.title")}</h2>
  <div class="dos-donts">
    <div class="dos-list">
      <h4>{t("logo.dos.title")}</h4>
      <ul>
        <li>{t("logo.dos.1")}</li>
        <li>{t("logo.dos.2")}</li>
        <li>{t("logo.dos.3")}</li>
        <li>{t("logo.dos.4")}</li>
      </ul>
    </div>
    <div class="donts-list">
      <h4>{t("logo.donts.title")}</h4>
      <ul>
        <li>{t("logo.donts.1")}</li>
        <li>{t("logo.donts.2")}</li>
        <li>{t("logo.donts.3")}</li>
        <li>{t("logo.donts.4")}</li>
        <li>{t("logo.donts.5")}</li>
      </ul>
    </div>
  </div>
</BrandLayout>

<style>
  .logo-card-icon img {
    max-height: 120px;
  }
</style>
