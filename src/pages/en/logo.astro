---
import BrandLayout from "@/layouts/BrandLayout.astro";
import { useTranslations } from "@/i18n/utils";

const t = useTranslations("en");
---

<BrandLayout title={t("logo.title")} lang="en" description={t("logo.intro")} activeSection="logo">
  <h1>{t("logo.h1")}</h1>
  <p class="brand-intro">{t("logo.intro")}</p>

  <h2>{t("logo.variants.title")}</h2>
  <p>{t("logo.variants.desc")}</p>

  <h3>{t("logo.primary.title")}</h3>
  <p>{t("logo.primary.desc")}</p>
  <div class="logo-grid">
    <div class="logo-card" style="background-color: #ffffff;">
      <img src="/images/logo/logo-primary.png" alt="Pantalytics primary logo (blue + gold) on white background" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Primary — white</span>
    </div>
    <div class="logo-card" style="background-color: var(--color-bg-primary);">
      <img src="/images/logo/logo-primary.png" alt="Pantalytics primary logo on dark background" />
      <span class="logo-card-label" style="color: var(--color-text-secondary);">Primary — dark</span>
    </div>
  </div>

  <h3>{t("logo.monochrome.title")}</h3>
  <p>{t("logo.monochrome.desc")}</p>
  <div class="logo-grid">
    <div class="logo-card" style="background-color: #ffffff;">
      <img src="/images/logo/logo-blue.png" alt="Pantalytics monochrome blue logo" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Monochrome blue</span>
    </div>
    <div class="logo-card" style="background-color: #ffffff;">
      <img src="/images/logo/logo-gold.png" alt="Pantalytics monochrome gold logo" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Monochrome gold</span>
    </div>
  </div>

  <h3>{t("logo.icon.title")}</h3>
  <p>{t("logo.icon.desc")}</p>
  <div class="logo-grid">
    <div class="logo-card logo-card-icon" style="background-color: #ffffff;">
      <img src="/images/logo/icon-blue.png" alt="Pantalytics icon mark blue" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Icon — blue</span>
    </div>
    <div class="logo-card logo-card-icon" style="background-color: #ffffff;">
      <img src="/images/logo/icon-gold.png" alt="Pantalytics icon mark gold" />
      <span class="logo-card-label" style="color: var(--color-text-inverse-secondary);">Icon — gold</span>
    </div>
    <div class="logo-card logo-card-icon" style="background-color: var(--color-bg-primary);">
      <img src="/images/logo/icon-blue.png" alt="Pantalytics icon mark blue on dark" />
      <span class="logo-card-label" style="color: var(--color-text-secondary);">Icon — blue/dark</span>
    </div>
  </div>

  <h2>{t("logo.clearspace.title")}</h2>
  <p>{t("logo.clearspace")}</p>

  <h2>{t("logo.minsize.title")}</h2>
  <p>{t("logo.minsize")}</p>

  <h2>{t("logo.dos.title")} & {t("logo.donts.title")}</h2>
  <div class="dos-donts">
    <div class="dos-list">
      <h4>{t("logo.dos.title")}</h4>
      <ul>
        <li>{t("logo.dos.1")}</li>
        <li>{t("logo.dos.2")}</li>
        <li>{t("logo.dos.3")}</li>
        <li>{t("logo.dos.4")}</li>
      </ul>
    </div>
    <div class="donts-list">
      <h4>{t("logo.donts.title")}</h4>
      <ul>
        <li>{t("logo.donts.1")}</li>
        <li>{t("logo.donts.2")}</li>
        <li>{t("logo.donts.3")}</li>
        <li>{t("logo.donts.4")}</li>
        <li>{t("logo.donts.5")}</li>
      </ul>
    </div>
  </div>
</BrandLayout>

<style>
  .logo-card-icon img {
    max-height: 120px;
  }
</style>
